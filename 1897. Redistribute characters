class Solution {
    public boolean makeEqual(String[] words) {

        int[] freq = new int[26];

        // Count frequency of all characters
        for (String word : words) {

            for (char ch : word.toCharArray()) {
                freq[ch - 'a']++;
            }
        }

        int n = words.length;

        // Check divisibility
        for (int count : freq) {

            if (count % n != 0) {
                return false;
            }
        }

        return true;
    }
}
