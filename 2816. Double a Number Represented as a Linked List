class Solution {

    public ListNode doubleIt(ListNode head) {

        // Reverse linked list
        head = reverse(head);

        ListNode curr = head;
        int carry = 0;

        // Double digits
        while (curr != null) {

            int sum = curr.val * 2 + carry;

            curr.val = sum % 10;
            carry = sum / 10;

            // Move ahead
            if (curr.next == null) {
                break;
            }

            curr = curr.next;
        }

        // If carry remains after last node
        if (carry > 0) {
            curr.next = new ListNode(carry);
        }

        // Reverse again
        return reverse(head);
    }

    // Reverse function
    private ListNode reverse(ListNode head) {

        ListNode prev = null;
        ListNode curr = head;

        while (curr != null) {

            ListNode nextNode = curr.next;

            curr.next = prev;

            prev = curr;
            curr = nextNode;
        }

        return prev;
    }
}
